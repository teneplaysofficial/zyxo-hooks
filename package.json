{
  "name": "@zyxo/hooks",
  "version": "0.0.0",
  "description": "Type-safe React hooks for modern web applications",
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "custom-hooks",
    "typescript",
    "react-library",
    "utility-hooks",
    "modern-react",
    "type-safe",
    "frontend"
  ],
  "homepage": "https://hooks.js.org",
  "repository": "git+https://github.com/teneplaysofficial/zyxo-hooks.git",
  "bugs": "https://github.com/teneplaysofficial/zyxo-hooks/issues",
  "funding": "https://github.com/sponsors/teneplaysofficial",
  "license": "Apache-2.0",
  "author": "Sriman",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.5.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "index.js",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "build:doc": "typedoc",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "husky",
    "test": "vitest run --coverage --environment jsdom --coverage.include=\"lib/use!(*.*).ts\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "19.x",
    "react-dom": "19.x"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tenedev/biome-config": "^0.0.0",
    "@tenedev/prettier-config": "^1.3.0",
    "@tenedev/tsconfig": "^0.0.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@vitest/coverage-v8": "^4.1.8",
    "echo-banner": "^0.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "prettier": "@tenedev/prettier-config",
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,ts}": "pnpm run lint:fix"
  }
}
